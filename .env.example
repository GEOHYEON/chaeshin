# Chaeshin Environment Variables
# Copy this file to .env and fill in your values
#   cp .env.example .env

# ── OpenAI (필수 — LLM + 임베딩) ──
OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM 모델 (선택, 기본값: gpt-4o-mini)
# CHAESHIN_LLM_MODEL=gpt-4o-mini

# 임베딩 모델 (선택, 기본값: text-embedding-3-small)
# CHAESHIN_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector DB (선택 — 프로덕션 사용 시) ──
# WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=your-weaviate-key

# PINECONE_API_KEY=your-pinecone-key
# PINECONE_ENVIRONMENT=us-east-1

# ── Logging ──
LOG_LEVEL=INFO
